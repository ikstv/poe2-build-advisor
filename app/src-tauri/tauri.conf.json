{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PoE 2 Build Advisor",
  "version": "0.1.0",
  "identifier": "com.poe2buildadvisor.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PoE 2 Build Advisor",
        "width": 960,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"]
  }
}
